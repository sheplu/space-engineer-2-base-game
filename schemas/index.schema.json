{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/sheplu/space-engineer-2-base-game/main/schemas/index.schema.json",
  "title": "SE2 Dataset Index",
  "description": "Shape of the root index.json file — a single-fetch discovery document listing every dataset in this repo.",
  "type": "object",
  "required": ["version", "generatedAt", "game", "totalEntries", "datasets"],
  "properties": {
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "generatedAt": { "type": "string", "format": "date" },
    "game": {
      "type": "object",
      "required": ["name", "stage", "dataAsOf"],
      "properties": {
        "name": { "type": "string" },
        "stage": { "type": "string" },
        "dataAsOf": { "type": "string", "format": "date" }
      }
    },
    "notes": { "type": "string" },
    "totalEntries": {
      "type": "integer",
      "minimum": 0,
      "description": "Sum of entryCount across every dataset. Useful as a cheap staleness signal."
    },
    "datasets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "path", "category", "subcategory", "description", "version", "entryCount"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+(/[a-z0-9-]+)*$" },
          "path": {
            "type": "string",
            "pattern": "^data/.+\\.json$",
            "description": "Repo-relative path to the dataset file."
          },
          "category": {
            "type": "string",
            "enum": ["resources", "components", "character", "blocks"]
          },
          "subcategory": { "type": "string" },
          "description": { "type": "string" },
          "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
          "entryCount": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
